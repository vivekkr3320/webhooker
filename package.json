{
  "name": "webhook-engine",
  "version": "2.0.0",
  "description": "Production-grade webhook delivery engine with HMAC signing, circuit breaker, rate limiting, Redis-backed distributed state, and a glassmorphism dashboard UI",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "prod:stop": "pm2 stop webhook-engine",
    "prod:reload": "pm2 reload webhook-engine",
    "logs": "pm2 logs webhook-engine",
    "monit": "pm2 monit",
    "setup": "node scripts/generate-api-key.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f webhook-engine"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6"
  },
  "optionalDependencies": {
    "bcrypt": "^6.0.0",
    "isolated-vm": "^6.1.2",
    "pm2": "^7.0.1"
  }
}
