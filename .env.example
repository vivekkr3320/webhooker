# ── Runtime ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Webhook Engine ────────────────────────────────────────────
# The HMAC signing secret used for all standard webhook deliveries.
# Override this with a strong random value in production.
WEBHOOK_SECRET=whsec_change_me_in_production

# ── Dashboard API Authentication ──────────────────────────────
# Generate this by running:   node scripts/generate-api-key.js
# The script prints your raw key once and writes the bcrypt hash here.
API_KEY_HASH=

# ── Storage Backend ───────────────────────────────────────────
# json  → local database.json file (single-node only)
# redis → distributed Redis store (required for horizontal scaling)
STORAGE_TYPE=json

# Redis connection string (used when STORAGE_TYPE=redis)
REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
